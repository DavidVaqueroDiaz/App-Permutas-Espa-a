# PLANTILLA de variables de entorno locales
#
# COMO USAR ESTO:
# 1. Copia este archivo y renombralo a `.env.local` (sin el .example).
# 2. Rellena cada valor con la clave real correspondiente.
# 3. NO commitees nunca el archivo `.env.local` (esta en .gitignore).
#
# Cuando despleguemos en Vercel, las MISMAS variables se configuran
# en el dashboard de Vercel, no en el repo.

# === Supabase ===
# Obten estos valores en: https://supabase.com/dashboard
#   Tu proyecto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Resend (email transaccional) ===
# Obten esta clave en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email "from" desde el que la app envia avisos.
# En desarrollo puedes usar "onboarding@resend.dev" (Resend lo permite gratis).
# En produccion habra que verificar tu dominio propio.
RESEND_FROM_EMAIL=onboarding@resend.dev
